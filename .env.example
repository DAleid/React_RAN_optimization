# ── Python backend — set these on Railway ────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
LLM_PROVIDER=groq
# PORT is injected automatically by Railway — do not set manually

# ── Next.js frontend — set this on Vercel ────────────────────────────────────
# Copy your Railway service URL here (e.g. https://xxx.railway.app)
BACKEND_URL=https://your-railway-service.railway.app
